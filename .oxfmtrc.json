{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    ".github/**",
    "**.md",
    "**/build/**",
    "src/profiling/proto/**",
    "src/instrumentations/external/fastify/*",
    "src/instrumentations/external/pg/**",
    "**.yml",
    "**.yaml"
  ],
  "arrowParens": "always",
  "singleQuote": true,
  "trailingComma": "es5"
}
